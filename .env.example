# ─── Base de datos ────────────────────────────────────────────────
# URL completa de conexión a PostgreSQL (Railway la genera automáticamente)
DATABASE_URL=postgres://usuario:contraseña@host:5432/cafeteria_db

# Host del servidor de base de datos
DB_HOST=localhost

# Puerto de PostgreSQL (por defecto 5432)
DB_PORT=5432

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL
DB_PASSWORD=

# Nombre de la base de datos
DB_NAME=cafeteria_db

# ─── Autenticación ────────────────────────────────────────────────
# Secreto para firmar los tokens JWT — usa un valor largo y aleatorio en producción
JWT_SECRET=cambia_esto_por_algo_seguro

# ─── Servidor ─────────────────────────────────────────────────────
# Puerto en que escucha la API (Railway lo asigna automáticamente con PORT)
PORT=3001

# Entorno de ejecución (development | production)
NODE_ENV=development

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:3000

# ─── Frontend (Nuxt 3) ────────────────────────────────────────────
# URL base de la API consumida por el frontend
NUXT_PUBLIC_API_URL=http://localhost:3001/api